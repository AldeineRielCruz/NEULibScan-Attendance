rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATTENDANCE SYSTEM SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a Role-Based Access Control (RBAC) model using a specialized 
     * 'roles_admin' lookup collection. It is designed to allow anonymous or authenticated 
     * students to submit attendance events while restricting data consumption (reading/listing) 
     * strictly to verified administrators.
     *
     * Data Structure:
     * - /attendanceRecords/{recordId}: A flat, top-level collection containing all check-in events.
     * - /roles_admin/{adminId}: A lookup collection where the existence of a document grants 
     *   admin-level permissions to the UID matching the document ID.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Read access for admins is determined by a direct 'exists()' 
     *    check on the roles collection, making the rules performant and independent of data hierarchy.
     * 2. Anonymous Submission: Since the app supports anonymous auth, 'create' operations on 
     *    attendance records are permitted for any authenticated user to ensure low-friction check-ins.
     * 3. Admin-Only Visibility: Only users with a record in 'roles_admin' can list or get individual 
     *    attendance records, protecting student privacy.
     * 4. Denormalization for Authorization: Student details (email, program) are stored directly 
     *    on each record to allow admins to perform complex filtering/reporting without additional joins.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from a signed-in user (Password or Anonymous). */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user is the owner of the document based on the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines admin check with existence check for safe updates/deletes. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the admin roles collection. Used for authorization lookups.
     * @path /roles_admin/{adminId}
     * @allow (get) If the user is viewing their own admin status.
     * @deny (create, update, delete) Prevents users from self-elevating their privileges.
     * @principle Role-based access control via document existence.
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId);
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via Firebase Console or Admin SDK
    }

    /**
     * @description Rules for student attendance records.
     * @path /attendanceRecords/{recordId}
     * @allow (create) Any authenticated user (including anonymous) can submit a record.
     * @allow (list, get) Only verified administrators can view attendance data.
     * @deny (update, delete) Non-admin users cannot modify or remove records once submitted.
     * @principle Public-write (authenticated) with Admin-only read access.
     */
    match /attendanceRecords/{recordId} {
      
      // Read Operations: Only Admins can see the data
      allow get, list: if isAdmin();

      // Create Operation: Allow students to check in. 
      // We validate that the internal 'id' matches the document path.
      allow create: if isSignedIn() && request.resource.data.id == recordId;

      // Write Operations: Only Admins can modify or delete existing records.
      allow update, delete: if isExistingAdmin();
    }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}